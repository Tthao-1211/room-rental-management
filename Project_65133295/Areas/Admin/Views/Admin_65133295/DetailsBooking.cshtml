@model Project_65133295.Models.Bookings

@{
    ViewBag.Title = "Booking Details";
    ViewBag.PageTitle = "Booking Details";
    ViewBag.PageDescription = "Review booking request #" + Model.BookingID;
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";

    var tenantName = Model.Users1 != null
        ? (Model.Users1.FirstName + " " + Model.Users1.LastName).Trim()
        : "Guest";
    var tenantEmail = Model.Users1 != null && !string.IsNullOrWhiteSpace(Model.Users1.Email)
        ? Model.Users1.Email
        : "N/A";
    var tenantPhone = Model.Users1 != null && !string.IsNullOrWhiteSpace(Model.Users1.PhoneNumber)
        ? Model.Users1.PhoneNumber
        : "N/A";

    var roomNumber = Model.Rooms != null && !string.IsNullOrWhiteSpace(Model.Rooms.RoomNumber) ? Model.Rooms.RoomNumber : "N/A";
    var roomTitle = Model.Rooms != null && !string.IsNullOrWhiteSpace(Model.Rooms.Title) ? Model.Rooms.Title : "N/A";
    var roomPrice = Model.Rooms != null ? Model.Rooms.Price.ToString("N0") + " đ" : "N/A";
    var depositAmount = Model.DepositAmount.HasValue ? Model.DepositAmount.Value.ToString("N0") + " đ" : "0 đ";
    var duration = Model.Duration.HasValue ? Model.Duration.Value + " tháng" : "N/A";
    var checkInDate = Model.CheckInDate.ToString("dd/MM/yyyy");
    var createdAt = Model.CreatedAt.HasValue ? Model.CreatedAt.Value.ToString("dd/MM/yyyy HH:mm") : "-";

    var statusClass = "bg-gray-100 text-gray-700 border border-gray-200";
    var statusLabel = Model.BookingStatus ?? "Không xác định";

    if (Model.BookingStatus == "Pending")
    {
        statusClass = "bg-yellow-100 text-yellow-700 border border-yellow-200";
        statusLabel = "Chờ duyệt";
    }
    else if (Model.BookingStatus == "Approved")
    {
        statusClass = "bg-green-100 text-green-700 border border-green-200";
        statusLabel = "Đã duyệt";
    }
    else if (Model.BookingStatus == "Rejected")
    {
        statusClass = "bg-red-100 text-red-700 border border-red-200";
        statusLabel = "Từ chối";
    }
    else if (Model.BookingStatus == "Cancelled")
    {
        statusClass = "bg-gray-100 text-gray-700 border border-gray-200";
        statusLabel = "Đã hủy";
    }
}

<div class="max-w-5xl mx-auto space-y-6">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
        <div>
            <a href="@Url.Action("ManageBookings", "Admin_65133295", new { area = "Admin" })" class="inline-flex items-center text-sm text-gray-500 hover:text-yellow-600 transition-colors mb-3">
                <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Back to bookings
            </a>

            <div class="flex flex-wrap items-center gap-3">
                <h2 class="text-2xl font-black text-gray-900">Booking #@Model.BookingID</h2>
                <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider @statusClass">
                    @statusLabel
                </span>
            </div>

            <p class="text-sm text-gray-500 mt-1">Tạo lúc @createdAt</p>
        </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
        <div class="xl:col-span-2 bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="p-6 border-b border-gray-100 bg-gray-50/60">
                <h3 class="text-xs font-black text-gray-400 uppercase tracking-widest">Tổng quan đặt phòng</h3>
                <p class="mt-1 text-sm text-gray-500">Thông tin chính của yêu cầu đặt phòng #@Model.BookingID.</p>
            </div>

            <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="rounded-2xl border border-gray-100 bg-gray-50/60 p-5">
                    <h4 class="text-xs font-black uppercase tracking-widest text-gray-400 mb-4">Khách thuê</h4>
                    <div class="flex items-center space-x-4">
                        <div class="w-12 h-12 rounded-xl bg-yellow-400 flex items-center justify-center text-white font-black text-lg shadow-sm">
                            @(string.IsNullOrEmpty(tenantName) ? "U" : tenantName.Substring(0, 1))
                        </div>
                        <div>
                            <p class="font-black text-gray-900">@tenantName</p>
                            <p class="text-sm text-gray-500">@tenantEmail</p>
                            <p class="text-sm text-gray-500">@tenantPhone</p>
                        </div>
                    </div>
                </div>

                <div class="rounded-2xl border border-gray-100 bg-gray-50/60 p-5">
                    <h4 class="text-xs font-black uppercase tracking-widest text-gray-400 mb-4">Phòng</h4>
                    <div class="space-y-2">
                        <p class="font-black text-gray-900">P.@roomNumber - @roomTitle</p>
                        <p class="text-sm text-gray-500">Giá: @roomPrice / tháng</p>
                        <p class="text-sm text-gray-500">Tiền cọc: @depositAmount</p>
                    </div>
                </div>

                <div class="rounded-2xl border border-gray-100 p-5">
                    <h4 class="text-xs font-black uppercase tracking-widest text-gray-400 mb-4">Lịch trình</h4>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <p class="text-xs text-gray-500">Ngày nhận phòng</p>
                            <p class="font-bold text-gray-900">@checkInDate</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500">Thời hạn</p>
                            <p class="font-bold text-gray-900">@duration</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500">Duyệt lúc</p>
                            <p class="font-bold text-gray-900">@(Model.ApprovedAt.HasValue ? Model.ApprovedAt.Value.ToString("dd/MM/yyyy HH:mm") : "-")</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500">Cập nhật lúc</p>
                            <p class="font-bold text-gray-900">@((Model.UpdatedAt.HasValue) ? Model.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm") : "-")</p>
                        </div>
                    </div>
                </div>

                <div class="rounded-2xl border border-gray-100 p-5">
                    <h4 class="text-xs font-black uppercase tracking-widest text-gray-400 mb-4">Ghi chú</h4>
                    <p class="text-sm text-gray-600 leading-6">
                        @(string.IsNullOrWhiteSpace(Model.Notes) ? "Không có ghi chú cho yêu cầu đặt phòng này." : Model.Notes)
                    </p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 h-fit">
            <h3 class="text-xs font-black text-gray-400 uppercase tracking-widest mb-4">Thao tác nhanh</h3>

            <div class="space-y-3">
                <div class="rounded-2xl bg-gray-50 border border-gray-100 p-4">
                    <p class="text-xs text-gray-500">Trạng thái</p>
                    <p class="font-black text-gray-900 mt-1">@statusLabel</p>
                </div>

                @if (Model.BookingStatus == "Pending")
                {
                    using (Html.BeginForm("ApproveBooking", "Admin_65133295", new { area = "Admin", id = Model.BookingID }, FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <button type="submit" class="w-full px-4 py-3 bg-green-600 text-white font-bold rounded-xl hover:bg-green-700 transition-colors">
                            Duyệt đặt phòng
                        </button>
                    }

                    using (Html.BeginForm("RejectBooking", "Admin_65133295", new { area = "Admin", id = Model.BookingID }, FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <button type="submit" class="w-full px-4 py-3 bg-red-600 text-white font-bold rounded-xl hover:bg-red-700 transition-colors">
                            Từ chối đặt phòng
                        </button>
                    }
                }
                else
                {
                    <div class="rounded-2xl border border-gray-100 bg-gray-50 p-4 text-sm text-gray-600">
                        Yêu cầu này không còn ở trạng thái chờ duyệt nên không thể thao tác.
                    </div>
                }

                <a href="@Url.Action("ManageBookings", "Admin_65133295", new { area = "Admin" })" class="w-full inline-flex items-center justify-center px-4 py-3 bg-gray-100 text-gray-700 font-bold rounded-xl hover:bg-gray-200 transition-colors">
                    Quay lại danh sách đặt phòng
                </a>
            </div>
        </div>
    </div>
</div>
