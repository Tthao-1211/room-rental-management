    @model IEnumerable<Project_65133295.Models.Bookings>

@{
    ViewBag.Title = "Manage Bookings";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<h2 class="text-xl font-bold text-gray-800 mb-4">Manage Bookings</h2>

<form method="get" class="mb-4 flex flex-col sm:flex-row gap-4">
    <div class="flex-1 relative">
        <input type="text" name="query" value="@ViewBag.CurrentQuery" placeholder="Search by customer name, room number..." 
               class="w-full pl-3 pr-10 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all">
    </div>
    <div class="w-full sm:w-auto">
        <select name="status" onchange="this.form.submit()" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none bg-white">
            <option value="">All statuses</option>
            <option value="Pending" @(ViewBag.CurrentStatus == "Pending" ? "selected" : "")>Pending</option>
            <option value="Approved" @(ViewBag.CurrentStatus == "Approved" ? "selected" : "")>Approved</option>
            <option value="Rejected" @(ViewBag.CurrentStatus == "Rejected" ? "selected" : "")>Rejected</option>
            <option value="Cancelled" @(ViewBag.CurrentStatus == "Cancelled" ? "selected" : "")>System Cancelled</option>
        </select>
    </div>
    <button type="submit" class="px-4 py-2 bg-gray-800 text-white font-medium rounded-lg hover:bg-gray-700 transition-colors">
        Filter
    </button>
    <a href="@Url.Action("ManageBookings","Admin_65133295", new { area = "Admin" })" class="px-4 py-2 bg-gray-100 text-gray-600 font-medium rounded-lg hover:bg-gray-200 transition-colors text-center">
        Refresh
    </a>
</form>

<div class="bg-white shadow-sm rounded-lg border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="min-w-full table-auto">
            <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                    <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Tenant</th>
                    <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Room</th>
                    <th class="px-6 py-4 text-center text-xs font-bold text-gray-500 uppercase tracking-wider">Check-in Date</th>
                    <th class="px-6 py-4 text-center text-xs font-bold text-gray-500 uppercase tracking-wider">Duration</th>
                    <th class="px-6 py-4 text-center text-xs font-bold text-gray-500 uppercase tracking-wider">Deposit</th>
                    <th class="px-6 py-4 text-center text-xs font-bold text-gray-500 uppercase tracking-wider">Status</th>
                    <th class="px-6 py-4 text-right text-xs font-bold text-gray-500 uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="px-6 py-12 text-center text-gray-500 italic">
                            No matching booking requests found.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50 transition-colors group">
                        <td class="px-6 py-4">
                            <div class="flex items-center">
                                <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-bold mr-3">
                                    @((item.Users1?.FirstName ?? "U").Substring(0, 1))
                                </div>
                                <div>
                                    <div class="text-sm font-bold text-gray-900">@item.Users1?.FirstName @item.Users1?.LastName</div>
                                    <div class="text-xs text-gray-500">@item.Users1?.PhoneNumber</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-sm text-gray-700">
                            <span class="font-bold text-blue-600">P.@item.Rooms?.RoomNumber</span><br />
                            <span class="text-xs text-gray-500">@item.Rooms?.Title</span>
                        </td>
                        <td class="px-6 py-4 text-sm text-gray-700 text-center">
                            @(item.CheckInDate.ToString("dd/MM/yyyy"))
                        </td>
                        <td class="px-6 py-4 text-sm text-gray-700 text-center font-medium">
                            @item.Duration months
                        </td>
                        <td class="px-6 py-4 text-sm text-gray-900 text-center font-bold">
                            @(item.DepositAmount?.ToString("N0") ?? "0") đ
                        </td>
                        <td class="px-6 py-4 text-center">
                            @switch (item.BookingStatus)
                            {
                                case "Pending":
                                    <span class="px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider rounded-full bg-yellow-100 text-yellow-700 border border-yellow-200">Pending</span>
                                    break;
                                case "Approved":
                                    <span class="px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider rounded-full bg-green-100 text-green-700 border border-green-200">Approved</span>
                                    break;
                                case "Rejected":
                                    <span class="px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider rounded-full bg-red-100 text-red-700 border border-red-200">Từ Chối</span>
                                    break;
                                case "Cancelled":
                                    <span class="px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider rounded-full bg-gray-100 text-gray-700 border border-gray-200">Cancelled</span>
                                    break;
                            }
                        </td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex justify-end space-x-2">
                                <a href="@Url.Action("DetailsBooking","Admin_65133295", new { area = "Admin", id = item.BookingID })" 
                                   class="p-2 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all" title="View Details">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                    </svg>
                                </a>
                                
                                @if (item.BookingStatus == "Pending")
                                {
                                    @* Approve form *@
                                    using (Html.BeginForm("ApproveBooking", "Admin_65133295", new { area = "Admin", id = item.BookingID }, FormMethod.Post, new { @class = "inline-block" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        <button type="submit" onclick="return confirm('Confirm approve?');" class="p-2 text-gray-400 hover:text-green-600 hover:bg-green-50 rounded-lg transition-all" title="Approve">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                            </svg>
                                        </button>
                                    }

                                    @* Reject form *@
                                    using (Html.BeginForm("RejectBooking", "Admin_65133295", new { area = "Admin", id = item.BookingID }, FormMethod.Post, new { @class = "inline-block" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        <button type="submit" onclick="return confirm('Confirm reject?');" class="p-2 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all" title="Reject">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                            </svg>
                                        </button>
                                    }
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
